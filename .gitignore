# Python bytecode
__pycache__/
*.py[cod]

# Virtual envs
.venv/
venv/
env/

# ML dataset
ml/data
ml/data/**

# checkpoints: model weights only, never tracked
ml/checkpoints/

# outputs: JSON metadata tracked, large binaries ignored
ml/outputs/**/*.npz
ml/outputs/**/*.bin

# Quartus generated folders
hardware/Quartus/**/db/
hardware/Quartus/**/incremental_db/
hardware/Quartus/**/greybox_tmp/
hardware/Quartus/**/qdb/
hardware/Quartus/**/hc_output/
hardware/Quartus/**/output_files/
hardware/Quartus/**/simulation/


# Compilation outputs
quartus/**/output_files/
*.sof
*.pof
*.jic
*.rbf
*.rpt
*.summary
*.smsg
*.done
*.qws
*.log

# Simulation junk
quartus/**/simulation/
transcript
*.wlf

# Verification: fixtures PNGs and meta tracked, large binaries ignored
verification/fixtures/**/*.bin

# Verification: vectors are fully generated — nothing tracked
verification/vectors/

# Verification: simulation results are generated — nothing tracked
verification/results/

# GHDL build artefacts
verification/sim/*.cf
*.ghw

